EXPO_PUBLIC_APP_NAME=react-native-posts-app
EXPO_PUBLIC_APP_SLUG=react-native-posts-app
EXPO_PUBLIC_APP_SCHEME=react-native-posts-app

# REST API (real backend)
EXPO_PUBLIC_API_BASE_URL=https://k8s.mectest.ru/test-app
# Any valid UUID works as auth token for this test backend
